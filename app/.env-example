# Copy this file to .env and fill in your values.
# For LocalStack (local dev), use the values below as-is.
# For real AWS, remove AWS_ENDPOINT_URL and set valid credentials.

AWS_REGION=us-east-1
DYNAMODB_TABLE=devices-local
S3_BUCKET=fleet-firmware-local

# Set to LocalStack endpoint for local dev; leave empty for real AWS
AWS_ENDPOINT_URL=http://localhost:4566

# AWS credentials (LocalStack accepts any non-empty value)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
